{
  "name": "@moku-labs/room",
  "version": "0.1.2",
  "description": "Couch-multiplayer foundation for Moku — shared screen + phones, WebRTC, multi-device state sync.",
  "keywords": [
    "moku",
    "couch-multiplayer",
    "local-multiplayer",
    "webrtc",
    "p2p",
    "trystero",
    "state-sync",
    "multiplayer",
    "plugin",
    "typescript"
  ],
  "homepage": "https://github.com/moku-labs/room#readme",
  "bugs": {
    "url": "https://github.com/moku-labs/room/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moku-labs/room.git"
  },
  "license": "MIT",
  "author": "Alex Kucherenko",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./browser": {
      "import": {
        "types": "./dist/browser.d.mts",
        "default": "./dist/browser.mjs"
      },
      "require": {
        "types": "./dist/browser.d.cts",
        "default": "./dist/browser.cjs"
      }
    },
    "./server": {
      "import": "./dist/server.mjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.3.14"
  },
  "peerDependencies": {
    "@moku-labs/web": "^1.12.4",
    "@moku-labs/worker": "^0.10.0"
  },
  "peerDependenciesMeta": {
    "@moku-labs/worker": {
      "optional": true
    }
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "trystero": "~0.25.2"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.3",
    "@arethetypeswrong/core": "0.18.3",
    "@biomejs/biome": "2.4.16",
    "@cloudflare/workers-types": "4.20260621.1",
    "@moku-labs/web": "1.12.4",
    "@moku-labs/worker": "0.10.0",
    "@playwright/test": "1.61.0",
    "@types/bun": "1.3.14",
    "@types/qrcode": "1.5.6",
    "@vitest/coverage-istanbul": "4.0.18",
    "eslint": "9.39.3",
    "eslint-config-biome": "2.1.3",
    "eslint-plugin-jsdoc": "62.6.0",
    "eslint-plugin-sonarjs": "4.0.0",
    "eslint-plugin-unicorn": "63.0.0",
    "globals": "17.4.0",
    "jiti": "2.6.1",
    "lefthook": "2.1.1",
    "publint": "0.3.21",
    "tsdown": "0.22.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.0",
    "vitest": "4.0.18",
    "wrangler": "4.103.0"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.worker.json",
    "validate": "publint && attw --pack . --profile node16 --exclude-entrypoints server",
    "lint": "biome check . && eslint .",
    "lint:fix": "biome check --write . && eslint --fix .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:coverage": "vitest run --project unit --project integration --coverage",
    "test:e2e": "playwright test",
    "test:e2e:worker": "playwright test -c playwright.worker.config.ts",
    "sandbox": "bun tests/sandbox/serve.ts",
    "sandbox:worker": "bun tests/sandbox/build-client.ts && wrangler dev --config tests/sandbox/wrangler.jsonc --port 5180 --persist-to .wrangler-sandbox"
  }
}
