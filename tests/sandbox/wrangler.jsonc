{
  // ─────────────────────────────────────────────────────────────────────────────────────────────────────
  // DEV-ONLY sandbox deployment config — TEST INFRASTRUCTURE, NOT the published @moku-labs/room package.
  //
  // The library ships NO wrangler config (D26): deployment is app-side, and a CONSUMER writes their own
  // wrangler.jsonc declaring the same bindings + pointing `main` at @moku-labs/room/server. This file is the
  // reference shape of that config, and the harness the worker Playwright e2e (`bun run test:e2e:worker`)
  // drives over real `workerd` via `wrangler dev` — the FIRST real-runtime coverage of the Hub DO
  // fetch()/Hibernation accept (W1–W3 unit-tested the dispatch via a fake). It is excluded from the npm
  // tarball by package.json `files` (only `dist/` ships).
  //
  // `bun run sandbox:worker` builds the client (build-client.ts) then boots this on :5180. The worker entry
  // (`../../src/server.ts`) serves the built web client through the ASSETS binding and hosts the per-room DO;
  // `run_worker_first` routes EVERY request through `app.hub.handle` (WS-upgrade → DO `101`, else →
  // `env.ASSETS` → `200`), exactly the routing api.ts implements (spec/07 §API).
  // ─────────────────────────────────────────────────────────────────────────────────────────────────────
  "name": "hub-sandbox",
  "main": "../../src/server.ts",
  "compatibility_date": "2026-06-17",

  // `nodejs_compat`: @moku-labs/worker@0.10.0 bundles its runtime plugins (kv/durableObjects/…) AND its
  // node-only deploy/cli graph into ONE chunk that imports `node:fs` at the top level, so when wrangler
  // re-bundles the package (it does, even though our published dist/server.mjs externalizes it) the unused
  // `node:fs` import comes along. The deploy code is NEVER executed at runtime (we only call
  // `app.hub.handle`); this flag just lets that dead import resolve so workerd boots. A consumer
  // pointing wrangler at `@moku-labs/room/server` needs the same flag until upstream splits the chunk —
  // see the W4 build report / STATE.md "Open Items".
  "compatibility_flags": ["nodejs_compat"],

  // Static web client (built into ./dist + the sibling HTML) served via the ASSETS Fetcher the worker calls.
  // `run_worker_first` makes the worker the sole entry so its WS-vs-assets routing is what gets exercised.
  // NOTE: this `assets.directory` (".") is also where wrangler would put `.wrangler/`; the DO's SQLite writes
  // then churn the watched dir and `wrangler dev` reloads on every WS message (dropping the persistent
  // signaling sockets). The `sandbox:worker` script therefore passes `--persist-to .wrangler-sandbox` to keep
  // local state OUT of the served/watched folder — REQUIRED for the reclaim e2e (persistent WS must survive).
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": true
  },

  // Per-room signaling hub — SQLite-backed (the DO uses `ctx.storage.sql`), so it MUST be a sqlite class.
  "durable_objects": {
    "bindings": [{ "name": "ROOM_HUB", "class_name": "Hub" }]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["Hub"] }],

  // Per-IP join rate-limit counter (D24). Local `wrangler dev` simulates KV; the `id` is a dev placeholder.
  "kv_namespaces": [{ "binding": "RATE_LIMIT", "id": "room_rate_limit_sandbox" }]
}
